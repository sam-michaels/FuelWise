# Where do we discover stations?
#   "osm"  — OpenStreetMap Overpass API (default, free, finds all stations)
#   "seed" — local JSON file (offline / dev mode)
STATION_PROVIDER=osm

# Where do we get prices?
#   "seed"   — illustrative prices from data/stations.json (default)
#   "quebec" — Régie de l'énergie open feed (Quebec only; requires URL below)
#   "null"   — no prices at all (just stations on the map)
PRICE_PROVIDER=seed

# Quebec only. Find this URL via Chrome DevTools → Network on
# regieessencequebec.ca. See comment block in quebecPriceProvider.js
# QUEBEC_REGIE_FEED_URL=https://...

# When you wire up crowdsourced reports
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
